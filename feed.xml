---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title>{{ site.title | xml_escape }}</title>
  <link href="{{ site.url }}{{ site.baseurl }}" rel="alternate"/>
  <link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self"/>
  <id>{{ site.url }}{{ site.baseurl }}/</id>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <author>
    <name>theluckystrike</name>
    <uri>https://zovo.one</uri>
  </author>
  <rights>Copyright (c) theluckystrike</rights>
  
  {% assign posts_sorted = site.posts | sort: 'date' | reverse %}
  {% for post in posts_sorted limit: 20 %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ site.baseurl }}{{ post.url }}" rel="alternate"/>
    <id>{{ site.url }}{{ site.baseurl }}{{ post.url }}</id>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <summary>{{ post.description | xml_escape }}</summary>
    <content type="html"><![CDATA[{{ post.content }}]]></content>
  </entry>
  {% endfor %}
</feed>
